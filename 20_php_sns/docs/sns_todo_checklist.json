    {
      "id": "home-controller",
      "title": "app/controllers/HomeController.php",
      "description": "ホーム画面のコントローラ。投稿詳細の取得と、投稿の登録処理を担います。",
      "blocks": [
        {
          "type": "subheading",
          "text": "detail() — 投稿IDの取得"
        },
        {
          "type": "items",
          "items": [
            {
              "id": "home-ctrl-1",
              "text": "$_GET から投稿ID を取得して $id に代入"
            }
          ]
        },
        {
          "type": "code",
          "language": "php",
          "code": "$id = $_GET['id'] ?? 0;"
        },
        {
          "type": "subheading",
          "text": "add() — 投稿処理"
        },
        {
          "type": "items",
          "items": [
            {
              "id": "home-ctrl-2",
              "text": "ログインユーザのIDを $posts['user_id'] にセット"
            },
            {
              "id": "home-ctrl-3",
              "text": "Tweet モデルの insert() にユーザIDと $posts を渡して投稿"
            }
          ]
        },
        {
          "type": "code",
          "language": "php",
          "code": "$tweet = new Tweet();\n$tweet->insert((int) $this->authUser['id'], $posts);"
        }
      ]
