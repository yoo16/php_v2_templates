    {
      "id": "model-tweet",
      "title": "app/models/Tweet.php",
      "description": "ツイートモデル。検索用のWHERE句、投稿SQL、投稿数カウントSQLを実装します。",
      "blocks": [
        {
          "type": "subheading",
          "text": "search() — キーワード検索のWHERE句"
        },
        {
          "type": "items",
          "items": [
            {
              "id": "tweet-1",
              "text": "$where に LIKE 検索の WHERE 句を設定（:keyword と :keyword_spaced の両方にマッチ）"
            },
            {
              "id": "tweet-2",
              "text": "$params に :keyword と :keyword_spaced のバインド値を設定"
            }
          ]
        },
        {
          "type": "code",
          "language": "php",
          "code": "$where  = '(tweets.message LIKE :keyword OR tweets.message LIKE :keyword_spaced)';\n$params = [\n    'keyword'        => \"%{$normalized}%\",\n    'keyword_spaced' => \"%{$spaced}%\",\n];"
        },
        {
          "type": "subheading",
          "text": "insert() — 投稿SQL"
        },
        {
          "type": "items",
          "items": [
            {
              "id": "tweet-3",
              "text": "tweets テーブルへ user_id, message, image_path を INSERT する SQL を $sql に設定"
            }
          ]
        },
        {
          "type": "code",
          "language": "php",
          "code": "$sql = \"INSERT INTO tweets (user_id, message, image_path)\n        VALUES (:user_id, :message, :image_path)\";"
        },
        {
          "type": "subheading",
          "text": "countByUserID() — 投稿数カウントSQL"
        },
        {
          "type": "items",
          "items": [
            {
              "id": "tweet-4",
              "text": "user_id を条件に tweets テーブルの件数を取得する SQL を $sql に設定"
            }
          ]
        },
        {
          "type": "code",
          "language": "php",
          "code": "$sql = \"SELECT COUNT(*) FROM tweets WHERE user_id = :user_id\";"
        }
      ]
    },
